# ════════════════════════════════════════════
# The Fair Digest — Environment Variables
# ════════════════════════════════════════════
# Copy this file to .env and fill in your values

# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MongoDB Connection URI (use MongoDB Atlas in production)
MONGODB_URI=mongodb://localhost:27017/fairdigest

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here_change_this

# NewsAPI.org API Key (free tier)
NEWS_API_KEY=your_newsapi_key_here

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS in production — set to your Vercel URL)
# Example: https://fair-digest.vercel.app
CLIENT_URL=http://localhost:5173
